{
  "name": "proofstake-offchain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ProofStake off-chain stack: x402-gated agents, verifier, and Base MCP router.",
  "scripts": {
    "agent:good": "cross-env AGENT_PROFILE=good PORT=4001 tsx agents/server.ts",
    "agent:mediocre": "cross-env AGENT_PROFILE=mediocre PORT=4002 tsx agents/server.ts",
    "agent:bad": "cross-env AGENT_PROFILE=malicious PORT=4003 tsx agents/server.ts",
    "agents": "concurrently -n good,mediocre,bad -c green,yellow,red \"npm:agent:good\" \"npm:agent:mediocre\" \"npm:agent:bad\"",
    "verifier": "tsx verifier/index.ts",
    "router": "tsx router/mcp.ts",
    "evidence": "cross-env EVIDENCE_PORT=4100 tsx evidence/store.ts",
    "smoke": "tsx scripts/smoke.ts",
    "client": "tsx scripts/client.ts",
    "challenge": "tsx scripts/challenge.ts",
    "demo": "tsx scripts/demo-testnet.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.2",
    "x402-express": "^0.3.0",
    "x402-fetch": "^1.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2"
  }
}
