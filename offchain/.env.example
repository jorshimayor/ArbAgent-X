# Shared — point RPC_URL at Base Sepolia for the live demo.
RPC_URL=https://sepolia.base.org
SKINBOOK_ADDR=0x...
CHAIN_ID=84532

# x402 reservation desk — leave X402_ENABLED=false to run the booking-fee paywall
# in self-contained demo mode (no funds move, full 402 handshake). Set true to
# settle real USDC via the facilitator.
X402_ENABLED=false
X402_NETWORK=base-sepolia
X402_FACILITATOR_URL=https://x402.org/facilitator
# Non-refundable booking fee charged per reservation call (USD).
BOOKING_FEE_USD=0.05
# Where the booking fee is paid. Leave unset to use a deterministic dev address.
# RESERVATION_PAYTO=0x...

# Keeper / arbiter — settles uncontested no-shows (anyone can) and resolves
# disputed no-shows (must match SkinBook.verifier()). For the demo this can be
# the same funded wallet as the deployer.
KEEPER_PRIVATE_KEY=0x...
