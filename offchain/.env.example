# Shared — point RPC_URL at Base Sepolia for the live demo.
RPC_URL=https://sepolia.base.org
PROOFSTAKE_ADDR=0x...
CHAIN_ID=84532

# Agent runner (per-process; the npm scripts set PORT + AGENT_PROFILE)
# AGENT_PROFILE=good|mediocre|malicious
# PORT=4001
AGENT_PRICE_USD=0.001
# Private key the agent uses to sign receipts (and as x402 payTo).
# Leave unset to use a deterministic dev key per profile (fine for the demo).
AGENT_PRIVATE_KEY=0x...

# x402 — leave X402_ENABLED=false to run the paywall in self-contained demo mode
# (no funds move, full handshake). Set true to settle real USDC via the facilitator.
X402_ENABLED=false
X402_NETWORK=base-sepolia
X402_FACILITATOR_URL=https://x402.org/facilitator
# Cap on any single x402 payment, in USDC base units (6dp). 1000000 = $1.
X402_MAX_VALUE=1000000

# Verifier — the trusted resolver wallet (must match ProofStake.verifier()).
VERIFIER_PRIVATE_KEY=0x...

# Client/challenger wallet — pays agents (when X402_ENABLED) and stakes challenge
# bonds. For the demo this can be the same funded wallet as the deployer/verifier.
CLIENT_PRIVATE_KEY=0x...

# Evidence store (stand-in for IPFS): where agents POST job records.
EVIDENCE_BASE_URL=http://127.0.0.1:4100

# Optional: deploy block of ProofStake, so the dashboard indexes full event history.
# PROOFSTAKE_START_BLOCK=
